{
  "manifest_version": 3,
  "name": "X Video Downloader",
  "version": "1.1.0",
  "description": "X(旧Twitter)の動画・GIFをワンクリックで保存。GIFは本物の.gifに変換、画質選択も可能。",
  "permissions": ["downloads", "storage"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.twimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["vendor/gifenc.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
