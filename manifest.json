{
  "manifest_version": 3,
  "name": "X Video Downloader",
  "version": "1.4.5",
  "description": "X(旧Twitter)の動画・GIF・画像とPixivの画像をワンクリックで保存。GIFは本物の.gifに変換、動画は画質選択、画像は原寸保存。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "X Video Downloader の設定",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["downloads", "storage", "declarativeNetRequest"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.twimg.com/*",
    "https://*.pixiv.net/*",
    "https://i.pximg.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "pximg_referer",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["vendor/gifenc.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.pixiv.net/*"],
      "js": ["pixiv.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
